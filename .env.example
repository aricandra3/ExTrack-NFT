# Telegram Bot Token dari @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenSea API Key (opsional, bisa kosong untuk rate limit rendah)
OPENSEA_API_KEY=

# Etherscan API Key (untuk fitur gas alert)
# Dapatkan gratis di https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Lokasi file database SQLite.
# Untuk deploy publik, gunakan volume/persistent path atau migrasi ke Postgres.
DATABASE_FILE=nft_tracker.db

# Cooldown notifikasi volume spike berulang, dalam detik.
VOLUME_ALERT_COOLDOWN_SECONDS=21600
